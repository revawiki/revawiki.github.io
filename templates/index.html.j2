<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ profile.name }} — {{ profile.title }}</title>
  <meta name="description" content="{{ profile.summary[:160] }}">
  <link rel="stylesheet" href="static/css/style.css">
  <link rel="icon" href="data:,">
</head>
<body>

{% macro icon(name) -%}
{%- if name == "mail" -%}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 6 9-6"/></svg>
{%- elif name == "linkedin" -%}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="8" y1="11" x2="8" y2="16"/><line x1="8" y1="8" x2="8" y2="8"/><path d="M12 16v-3a2 2 0 0 1 4 0v3"/><line x1="12" y1="11" x2="12" y2="16"/></svg>
{%- elif name == "github" -%}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48v-1.7c-2.78.6-3.37-1.34-3.37-1.34-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.89 1.52 2.34 1.08 2.91.83.09-.65.35-1.09.64-1.34-2.22-.25-4.56-1.11-4.56-4.93 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.64 0 0 .84-.27 2.75 1.03a9.55 9.55 0 0 1 5 0c1.91-1.3 2.75-1.03 2.75-1.03.55 1.37.2 2.39.1 2.64.64.7 1.03 1.59 1.03 2.68 0 3.83-2.35 4.68-4.58 4.92.36.31.68.92.68 1.85v2.74c0 .26.18.57.69.48A10 10 0 0 0 12 2z"/></svg>
{%- elif name == "twitter" -%}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 4l16 16M20 4L4 20"/></svg>
{%- elif name == "instagram" -%}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.2" cy="6.8" r="0.6" fill="currentColor" stroke="none"/></svg>
{%- elif name == "whatsapp" -%}
<svg viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38c1.45.79 3.08 1.21 4.79 1.21h.01c5.46 0 9.91-4.45 9.91-9.91S17.5 2 12.04 2zm0 1.67c4.55 0 8.25 3.7 8.25 8.25 0 4.55-3.7 8.25-8.25 8.25-1.6 0-3.16-.46-4.5-1.32l-.32-.2-3.1.82.83-3.02-.21-.31a8.18 8.18 0 0 1-1.25-4.22c0-4.55 3.7-8.25 8.25-8.25zm-2.2 4.43c-.17 0-.45.06-.66.31-.21.25-.8.78-.8 1.9 0 1.12.81 2.2 1.43 2.94.62.74 2.4 2.6 4.18 3.13.3.09 1.07.22 1.84-.13.55-.25 1.43-.96 1.62-1.4.19-.44.19-.82.13-.9-.06-.08-.45-.24-.74-.38-.29-.13-1.07-.5-1.24-.55-.17-.06-.3-.09-.43.09-.13.18-.5.62-.61.74-.11.13-.22.14-.41.05-.19-.09-.8-.3-1.52-.95-.56-.5-.94-1.12-1.05-1.31-.11-.19-.01-.29.08-.4.09-.11.41-.51.52-.69.11-.18.06-.33-.01-.45-.08-.13-.34-.82-.47-1.13-.13-.31-.27-.27-.38-.27z"/></svg>
{%- elif name == "resume" -%}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M12 18v-6"/><path d="M9 15l3 3 3-3"/></svg>
{%- elif name == "award" -%}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="9" r="5"/><path d="M9 13.5L7 21l5-2 5 2-2-7.5"/></svg>
{%- elif name == "chevron" -%}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M9 6l6 6-6 6"/></svg>
{%- endif -%}
{%- endmacro %}

{% macro cta_icons() -%}
<a href="mailto:{{ profile.email }}" class="icon-btn" title="Email" aria-label="Email">{{ icon("mail") }}</a>
<a href="{{ profile.whatsapp }}" class="icon-btn" target="_blank" rel="noopener" title="WhatsApp" aria-label="WhatsApp">{{ icon("whatsapp") }}</a>
<a href="{{ profile.linkedin }}" class="icon-btn" target="_blank" rel="noopener" title="LinkedIn" aria-label="LinkedIn">{{ icon("linkedin") }}</a>
<a href="{{ profile.github }}" class="icon-btn" target="_blank" rel="noopener" title="GitHub" aria-label="GitHub">{{ icon("github") }}</a>
<a href="{{ profile.twitter }}" class="icon-btn" target="_blank" rel="noopener" title="Twitter / X" aria-label="Twitter / X">{{ icon("twitter") }}</a>
<a href="{{ profile.instagram }}" class="icon-btn" target="_blank" rel="noopener" title="Instagram" aria-label="Instagram">{{ icon("instagram") }}</a>
{%- endmacro %}

  <header class="hero">
    <div class="container hero-inner">
      {% if profile.photo %}
      <img src="{{ profile.photo }}" alt="{{ profile.name }}" class="hero-photo">
      {% else %}
      <div class="hero-photo-fallback">{{ profile.name.split()[0][0] }}{{ profile.name.split()[-1][0] }}</div>
      {% endif %}
      <div>
        <p class="hero-eyebrow">Portfolio</p>
        <h1>{{ profile.name }}</h1>
        <p class="hero-title">{{ profile.title }}</p>
        <p class="hero-location">{{ profile.location }}</p>
        <nav class="cta-row">{{ cta_icons() }}</nav>
        <a class="resume-cta" href="{{ profile.resume }}" target="_blank" rel="noopener" download>{{ icon("resume") }} Download Resume</a>
      </div>
    </div>
  </header>

  <main>

    <section class="section" id="about">
      <div class="container">
        <h2>Profile</h2>
        <p class="summary">{{ profile.summary }}</p>

        <details class="expand-link">
          <summary>{{ icon("chevron") }} Domain Knowledge</summary>
          <div class="stack-rows">
            {% for group in domain_knowledge %}
            <div class="stack-row">
              <p class="stack-group">{{ group['group'] }}</p>
              <ul class="tag-list">
                {% for item in group['items'] %}<li>{{ item }}</li>{% endfor %}
              </ul>
            </div>
            {% endfor %}
          </div>
        </details>

        <details class="expand-link">
          <summary>{{ icon("chevron") }} Tools</summary>
          <div class="stack-rows">
            {% for group in tools %}
            <div class="stack-row">
              <p class="stack-group">{{ group['group'] }}</p>
              <ul class="tag-list">
                {% for item in group['items'] %}<li>{{ item }}</li>{% endfor %}
              </ul>
            </div>
            {% endfor %}
          </div>
        </details>

        <a class="credly-link" href="{{ profile.credly }}" target="_blank" rel="noopener">{{ icon("award") }} View industry certifications</a>
      </div>
    </section>

    <section class="section section-alt" id="work">
      <div class="container">
        <h2>Featured Work</h2>
        <div class="catalog-grid">
          {% for w in works %}
          <details class="catalog-card" id="work-{{ loop.index }}">
            <summary>
              <h3>{{ w.name }}</h3>
              <p class="catalog-role">{{ w.role }}</p>
              <p class="catalog-tagline">{{ w.tagline }}</p>
              <span class="catalog-expand">View details ↓</span>
            </summary>
            <div class="catalog-body">
              <h4>Challenge</h4>
              <p>{{ w.challenge }}</p>

              <h4>Action</h4>
              {% if w.diagram %}
              <img src="{{ w.diagram }}" alt="{{ w.name }} architecture diagram" class="catalog-diagram">
              {% endif %}
              <p>{{ w.action }}</p>

              {% if w.code_samples %}
              <div class="code-samples">
                {% for sample in w.code_samples %}
                <div class="code-block">
                  <p class="code-filename">{{ sample.filename }}</p>
                  <pre><code>{{ sample.code | e }}</code></pre>
                </div>
                {% endfor %}
              </div>
              {% endif %}

              {% if w.pillars %}
              <div class="pillar-grid">
                {% for pillar in w.pillars %}
                <div class="pillar-card">
                  <h5>{{ pillar.title }}</h5>
                  <p>{{ pillar.desc }}</p>
                </div>
                {% endfor %}
              </div>
              {% endif %}

              <h4>Result</h4>
              {% if w.result_intro %}
              <p>{{ w.result_intro }}</p>
              {% endif %}
              {% if w.result is string %}
              <p>{{ w.result }}</p>
              {% elif w.result[0] is mapping %}
              <div class="outcome-grid">
                {% for o in w.result %}
                <div class="outcome-card">
                  <p class="outcome-metric">{{ o.metric }}</p>
                  <p class="outcome-label">{{ o.label }}</p>
                </div>
                {% endfor %}
              </div>
              {% else %}
              <p class="result-label">Benefits of this approach:</p>
              <ul class="result-list">
                {% for item in w.result %}<li>{{ item }}</li>{% endfor %}
              </ul>
              {% endif %}
              {% if w.note %}
              <p class="catalog-note">{{ w.note }}</p>
              {% endif %}
            </div>
          </details>
          {% endfor %}
        </div>
      </div>
    </section>

    <section class="section" id="experience">
      <div class="container">
        <h2>Experience</h2>
        <div class="timeline">
          {% for job in experience %}
          <div class="job-card">
            <div class="job-company-row">
              <a href="{{ job.company_url }}" target="_blank" rel="noopener" class="company-logo-link">
                <img src="{{ job.company_logo }}" alt="" class="company-logo" loading="lazy">
                <span class="company-name">{{ job.company }}</span>
              </a>
            </div>
            <h3>{{ job.role }}</h3>
            <p class="job-meta">{{ job.period }}</p>
            <p class="job-narrative">{{ job.narrative }}</p>
            {% if job.stack %}
            <details class="job-stack">
              <summary>Tech stack managed</summary>
              <div class="stack-rows">
                {% for group in job.stack %}
                <div class="stack-row">
                  <p class="stack-group">{{ group.category }}</p>
                  <ul class="tag-list">
                    {% for item in group['items'] %}<li>{{ item }}</li>{% endfor %}
                  </ul>
                </div>
                {% endfor %}
              </div>
            </details>
            {% endif %}
            {% if job.featured_link %}
            <a class="project-jump" href="#work">See featured work ↑</a>
            {% endif %}
          </div>
          {% endfor %}
        </div>
      </div>
    </section>

    <section class="section section-alt" id="education">
      <div class="container">
        <h2>Education</h2>
        <div class="education-grid">
          {% for ed in education %}
          <div class="education-card">
            <p class="education-school">{{ ed.school }}</p>
            <p class="education-degree">{{ ed.degree }}</p>
            <p class="education-year">{{ ed.year }}</p>
          </div>
          {% endfor %}
        </div>
      </div>
    </section>

  </main>

  <footer class="footer">
    <div class="container">
      <p>{{ profile.name }} — {{ profile.title }}</p>
      <nav class="cta-row">{{ cta_icons() }}</nav>
      <p class="footer-tagline">Made with ☕ and ❤️ - with (extra) help from Claude 🤖</p>
    </div>
  </footer>

</body>
</html>
