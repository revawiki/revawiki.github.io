<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ profile.name }} — {{ profile.title }}</title>
  <meta name="description" content="{{ profile.summary[:160] }}">
  <link rel="stylesheet" href="static/css/style.css">
  <link rel="icon" href="data:,">
</head>
<body>

  <header class="hero">
    <div class="container">
      <p class="hero-eyebrow">Portfolio</p>
      <h1>{{ profile.name }}</h1>
      <p class="hero-title">{{ profile.title }}</p>
      <p class="hero-location">{{ profile.location }}</p>
      <nav class="hero-links">
        <a href="mailto:{{ profile.email }}">Email</a>
        <a href="{{ profile.linkedin }}" target="_blank" rel="noopener">LinkedIn</a>
        <a href="{{ profile.github }}" target="_blank" rel="noopener">GitHub</a>
      </nav>
    </div>
  </header>

  <main>

    <section class="section" id="about">
      <div class="container">
        <h2>Profile</h2>
        <p class="summary">{{ profile.summary }}</p>
        <div class="competency-grid">
          {% for group in core_competencies %}
          <div class="competency-card">
            <h3>{{ group.group }}</h3>
            <ul class="tag-list">
              {% for item in group['items'] %}<li>{{ item }}</li>{% endfor %}
            </ul>
          </div>
          {% endfor %}
        </div>
      </div>
    </section>

    <section class="section section-alt" id="project">
      <div class="container">
        <h2>Featured Project</h2>
        <div class="project-card">
          <div class="project-head">
            <h3>{{ project.name }}</h3>
            <p class="project-role">{{ project.role }}</p>
          </div>
          <p class="project-tagline">{{ project.tagline }}</p>

          <h4>The Problem</h4>
          <p>{{ project.problem }}</p>

          <h4>Strategic Pillars</h4>
          <div class="pillar-grid">
            {% for pillar in project.pillars %}
            <div class="pillar-card">
              <h5>{{ pillar.title }}</h5>
              <p>{{ pillar.desc }}</p>
            </div>
            {% endfor %}
          </div>

          <h4>Approach</h4>
          <p>{{ project.approach }}</p>

          <h4>Outcomes</h4>
          <div class="outcome-grid">
            {% for o in project.outcomes %}
            <div class="outcome-card">
              <p class="outcome-metric">{{ o.metric }}</p>
              <p class="outcome-label">{{ o.label }}</p>
            </div>
            {% endfor %}
          </div>
          <p class="project-note">{{ project.note }}</p>
        </div>
      </div>
    </section>

    <section class="section" id="experience">
      <div class="container">
        <h2>Experience</h2>
        <div class="timeline">
          {% for job in experience %}
          <div class="timeline-item">
            <div class="timeline-meta">
              <p class="timeline-period">{{ job.period }}</p>
            </div>
            <div class="timeline-content">
              <h3>{{ job.role }}</h3>
              <p class="timeline-company">{{ job.company }}</p>
              <p class="timeline-narrative">{{ job.narrative }}</p>
              <details class="timeline-details">
                <summary>Key achievements</summary>
                <ul>
                  {% for b in job.bullets %}<li>{{ b }}</li>{% endfor %}
                </ul>
              </details>
              {% if job.featured_link %}
              <a class="project-jump" href="#project">View the Unified L1 Autopilot project ↑</a>
              {% endif %}
            </div>
          </div>
          {% endfor %}
        </div>
      </div>
    </section>

    <section class="section section-alt" id="skills">
      <div class="container">
        <h2>Technical Skills</h2>
        <div class="skills-grid">
          {% for group in technical_skills %}
          <div class="skills-row">
            <p class="skills-group">{{ group.group }}</p>
            <ul class="tag-list">
              {% for item in group['items'] %}<li>{{ item }}</li>{% endfor %}
            </ul>
          </div>
          {% endfor %}
        </div>
      </div>
    </section>

    <section class="section" id="certifications">
      <div class="container">
        <h2>Certifications</h2>
        <ul class="cert-list">
          {% for cert in certifications %}<li>{{ cert }}</li>{% endfor %}
        </ul>
      </div>
    </section>

    <section class="section section-alt" id="education">
      <div class="container">
        <h2>Education</h2>
        <div class="education-grid">
          {% for ed in education %}
          <div class="education-card">
            <p class="education-school">{{ ed.school }}</p>
            <p class="education-degree">{{ ed.degree }}</p>
            <p class="education-year">{{ ed.year }}</p>
          </div>
          {% endfor %}
        </div>
      </div>
    </section>

  </main>

  <footer class="footer">
    <div class="container">
      <p>{{ profile.name }} — {{ profile.title }}</p>
      <nav class="hero-links">
        <a href="mailto:{{ profile.email }}">Email</a>
        <a href="{{ profile.linkedin }}" target="_blank" rel="noopener">LinkedIn</a>
        <a href="{{ profile.github }}" target="_blank" rel="noopener">GitHub</a>
      </nav>
    </div>
  </footer>

</body>
</html>
